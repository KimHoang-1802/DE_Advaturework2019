    p.ProductID,
    p.ProductName,
    p.ProductNumber,
    isnull(p.Color, ''0'') as Color,
    isnull(p.Size, ''0'') as Size,
    isnull(p.Style, ''0'') as Style,
    isnull(p.SubCatProductID, 0) as SubCatProductID,
    isnull(sc.SubCatProductName, ''0'') as SubCatProductName,
    isnull(sc.CaProductID, 0) as CaProductID,
    isnull(ca.CaProductName, ''0'') as CaProductName,
